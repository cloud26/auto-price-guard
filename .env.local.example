# 复制为 .env.local 后填入真实值，.env.local 已在 .gitignore 中
# 发布前执行：set -a && source .env.local && set +a && pnpm run publish

# macOS 代码签名证书名（Keychain 中的证书 Common Name）
CSC_NAME="Your Name (TEAMID)"

# Apple 公证
APPLE_ID="your-apple-id@example.com"
APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
APPLE_TEAM_ID="TEAMID"

# GitHub 发布 token（repo 权限）
GH_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"
