{
  "name": "auto-price-guard",
  "version": "1.1.0",
  "description": "京东 / 淘宝价格保护自动申请工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:dir": "electron-builder --mac dir",
    "publish": "electron-builder --mac --publish always",
    "release": "bash -c 'set -a && source .env.local && set +a && electron-builder --mac --publish always'"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "build": {
    "appId": "com.auto-price-guard",
    "productName": "价保助手",
    "afterSign": "build/notarize.js",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "files": [
      "main.js",
      "preload.js",
      "tb-preload.js",
      "index.html",
      "renderer.js"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "cloud26",
        "repo": "auto-price-guard"
      }
    ],
    "artifactName": "${name}-${version}-${arch}.${ext}"
  }
}
